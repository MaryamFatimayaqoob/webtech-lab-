      </div>

      <div class="col-sm-6 col-lg-3">
        <div class="card product-card border-0 shadow-sm">
          <img src="https://images.unsplash.com/photo-1585386959984-6f9c0929180a?auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Velora Sneaker 3">
          <div class="card-body text-center">
            <h6 class="fw-bold">Urban Pulse</h6>
            <p class="text-muted">$130</p>
            <button class="btn btn-dark btn-sm">Add to Cart</button>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3">
        <div class="card product-card border-0 shadow-sm">
          <img src="https://images.unsplash.com/photo-1585386959984-5c7e6f8e8a2a?auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Velora Sneaker 4">
